# Variaveis de ambiente para Open5GS + srsRAN CU/DU

OPEN5GS_IMAGE=gradiant/open5gs:2.7.6
MONGODB_IMAGE=mongo:7.0
UERANSIM_IMAGE=gradiant/ueransim:3.2.7
WEBUI_IMAGE=gradiant/open5gs-webui:2.7.6
DN_IMAGE=alpine:latest

# Caminho E2E validado: gnb_split_8 + srsUE via ZMQ
SRSRAN_CU_DU_IMAGE=aetherproject/srsran-gnb:rel-0.7.0

# Caminho CU/DU estrito: srscu + srsdu em containers separados.
# Construa com ./scripts/build-srsran-cudu-zmq.sh ou aponte para uma imagem
# equivalente que tenha srscu, srsdu e ZMQ habilitado.
SRSRAN_STRICT_CU_DU_IMAGE=open5gs-srsran-cudu-zmq:latest
SRSRAN_UE_IMAGE=srsue:latest
