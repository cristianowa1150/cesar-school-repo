# Variáveis de ambiente para Open5GS + RAN (UERANSIM/srsRAN)
# Copie para .env: cp .env.example .env

OPEN5GS_IMAGE=gradiant/open5gs:2.7.6
MONGODB_IMAGE=mongo:7.0
UERANSIM_IMAGE=gradiant/ueransim:3.2.7
WEBUI_IMAGE=gradiant/open5gs-webui:2.7.6
DN_IMAGE=alpine:latest

# srsRAN (profile srsran)
# SRSRAN_GNB_IMAGE=srsran/gnb:latest  # Pode precisar build com ZMQ
# SRSRAN_UE_IMAGE=srsue:latest         # Build: ./scripts/build-srsue.sh

# Subnet UE (para NAT no host)
# UE_SUBNET=10.60.0.0/16
